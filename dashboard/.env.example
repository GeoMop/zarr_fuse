# HoloViz Dashboard Environment Configuration
# Copy this to .env and fill in your values

# REQUIRED: Which endpoint to use (must exist in your endpoints.yaml)
HV_DASHBOARD_ENDPOINT=your_endpoint_name_here

# OPTIONAL: Path to your endpoints.yaml file
# If not set, uses packaged default: config/endpoints.yaml
ENDPOINTS_PATH=path_to_your_endpoints_yaml_here

# OPTIONAL: S3 Configuration (required only if your endpoint uses S3)
ZF_S3_ACCESS_KEY=your_access_key_here
ZF_S3_SECRET_KEY=your_secret_key_here
ZF_S3_ENDPOINT_URL=https://your-endpoint-url

# OPTIONAL: Tile Service Configuration
# TILE_BUCKET=app-databuk-test-service
# TILE_PREFIX=test_tiles/
# ZF_CACHE_DIR=/tmp/zf_tiles

# OPTIONAL: Server Binding Configuration
# SERVE_BIND=0.0.0.0
# SERVE_PORT=5006

# OPTIONAL: API Configuration (if using FastAPI backend)
# HV_API_URL=http://localhost:8000
